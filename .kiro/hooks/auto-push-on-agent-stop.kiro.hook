{
  "enabled": true,
  "name": "Auto Push to GitHub",
  "description": "Tự động git add, commit và push lên GitHub sau mỗi lần agent hoàn thành công việc",
  "version": "1",
  "when": {
    "type": "agentStop"
  },
  "then": {
    "type": "runCommand",
    "command": "cd \"C:\\Users\\Heavietnam\\Desktop\\Dự án kiến lửa\\wiki\" && git add -A && git diff --cached --quiet || git commit -m \"chore: auto-sync changes\" && git push origin main",
    "timeout": 60
  }
}